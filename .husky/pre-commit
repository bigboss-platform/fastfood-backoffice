echo "Running type check..."
pnpm type-check
if [ $? -ne 0 ]; then
  echo "Type check failed. Commit aborted."
  exit 1
fi

echo "Running lint..."
pnpm lint
if [ $? -ne 0 ]; then
  echo "Lint failed. Commit aborted."
  exit 1
fi

echo "Running unit tests..."
pnpm test:ci
if [ $? -ne 0 ]; then
  echo "Unit tests failed. Commit aborted."
  exit 1
fi

echo "All checks passed."
